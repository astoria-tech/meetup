---
import MainLayout from "../layouts/MainLayout.astro";
import { getLink } from "../components/Link.astro";

const donors = [
  { name: "Camille Sato" },
  { name: "Carlos Campoy" },
  { name: "Craig Webb" },
  { name: "Devin Viss" },
  { name: "Elliott King" },
  { name: "Fahad H" },
  { name: "Ian LeRoy" },
  { name: "Jawaun Brown" },
  { name: "Maria Pia" },
  { name: "Nancy Zhang" },
  { name: "Peter Valdez" },
  { name: "Rachel Dean" },
  { name: "Robin Kwong" },
  { name: "Rogerio Shieh" },
  { name: "Stefan Buszwatiuk" },
  { name: "Tatsuya E" },
  { name: "Tea Reggi" },
  { name: "William Hutson" },
  { name: "Yassine Khayati" },
];

donors.sort((a, b) => a.name.localeCompare(b.name));

// Styles to cycle through for the donor list
const donorStyles = [
  {
    emoji: "🌟",
    color: "yellow",
    rotate: "-rotate-1",
    size: "text-xl py-2 px-4",
  },
  {
    emoji: "💖",
    color: "green",
    rotate: "rotate-1",
    size: "text-xl py-2 px-4",
  },
  {
    emoji: "🚀",
    color: "blue",
    rotate: "-rotate-2",
    size: "text-xl py-2 px-4",
  },
  {
    emoji: "✨",
    color: "purple",
    rotate: "rotate-2",
    size: "text-xl py-2 px-4",
  },
  {
    emoji: "🎉",
    color: "pink",
    rotate: "-rotate-1",
    size: "text-xl py-2 px-4",
  },
  {
    emoji: "💡",
    color: "indigo",
    rotate: "rotate-1",
    size: "text-xl py-2 px-4",
  },
  { emoji: "🏆", color: "red", rotate: "-rotate-2", size: "text-xl py-2 px-4" },
  { emoji: "🎈", color: "teal", rotate: "rotate-2", size: "text-xl py-2 px-4" },
];

// Sage green color variations for donors
const sageGreenVariations = [
  "bg-emerald-50 text-emerald-800 border-emerald-200",
  "bg-green-50 text-green-800 border-green-200",
  "bg-teal-50 text-teal-800 border-teal-200",
  "bg-lime-50 text-lime-800 border-lime-200",
];
---

<MainLayout title="Donations - Astoria Tech Meetup">
  <!-- Page header -->
  <section class="mb-10">
    <div class="max-w-4xl text-center mx-auto">
      <h1 class="text-3xl font-bold text-emerald-900 mb-4">
        Support Astoria Tech Meetup
      </h1>
      <p class="text-lg text-emerald-800 mb-6">
        Help us keep our grassroots tech community thriving with your generous
        support.
      </p>
      <a
        href={getLink("/donate")}
        class="donate-btn inline-block bg-gradient-to-r from-emerald-600 to-emerald-500 hover:from-emerald-700 hover:to-emerald-600 text-white font-bold py-3.5 px-10 rounded-full text-lg shadow-lg shadow-emerald-600/20"
      >
        Donate Now
      </a>
    </div>
  </section>
  <!-- Progress section -->
  <section class="bg-white rounded-lg border border-green-200 p-6 mb-8">
    <div class="mb-6">
      <div class="text-center mb-3 text-lg text-emerald-900 font-semibold">
        Raised: $485 / $3,257 (costs to date)
      </div>
      <div class="w-full bg-emerald-100 rounded-full h-6">
        <div
          class="bg-emerald-600 h-6 rounded-full text-xs font-medium text-white text-center p-0.5 leading-none"
          style="width: 14.9%"
        >
          15%
        </div>
      </div>
    </div>
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-emerald-700 mb-4">
        We deeply appreciate the incredible support from our community.
      </p>
      <p class="text-emerald-700 mb-4">
        All donations go directly towards covering the operational costs of the
        Astoria Tech Meetup. This mainly covers costs such as venue space and
        Meetup.com fees.
      </p>
      <p class="text-emerald-700">
        Your contributions help us keep the meetups running smoothly and
        accessible to everyone, and are never used for anything else.
      </p>
    </div>
  </section>

  <!-- Donors section -->
  <section class="bg-white rounded-lg border border-green-200 p-6 mb-8">
    <h2 class="text-2xl font-bold mb-4 text-center text-emerald-900">
      Thank You to Our Donors
    </h2>

    <div class="flex flex-wrap justify-center items-center gap-4">
      {
        donors.map((donor, index) => {
          const style = donorStyles[index % donorStyles.length];
          const colorClass =
            sageGreenVariations[index % sageGreenVariations.length];
          return (
            <span
              class:list={[
                colorClass,
                style.size,
                style.rotate,
                "rounded-lg border hover:scale-105 transition-transform shadow-sm",
              ]}
            >
              {style.emoji} {donor.name}
            </span>
          );
        })
      }
    </div>
  </section>
</MainLayout>

<style>
  .donate-btn {
    position: relative;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      background-color 0.2s ease;
    animation: gentle-sway 4s ease-in-out infinite;
  }

  .donate-btn::after {
    content: "";
    position: absolute;
    top: -50%;
    left: -75%;
    width: 50%;
    height: 200%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.15) 45%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.15) 55%,
      transparent 60%
    );
    animation: sheen 6s ease-in-out infinite;
  }

  .donate-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 10px 25px rgba(5, 150, 105, 0.35);
    animation: hover-sway 2s ease-in-out infinite;
  }

  .donate-btn:hover::after {
    animation: none;
    opacity: 0;
  }

  @keyframes hover-sway {
    0%,
    100% {
      transform: translateY(-3px) scale(1.05) rotate(-1deg);
    }
    50% {
      transform: translateY(-4px) scale(1.05) rotate(1deg);
    }
  }

  @keyframes sheen {
    0%,
    78% {
      left: -75%;
    }
    88% {
      left: 125%;
    }
    100% {
      left: 125%;
    }
  }

  @keyframes gentle-sway {
    0%,
    100% {
      transform: translateY(0px) rotate(-0.8deg);
    }
    50% {
      transform: translateY(-3px) rotate(0.8deg);
    }
  }
</style>
